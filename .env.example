# =====================================================
# zoom-course-automation 環境変数テンプレート
# =====================================================
#
# このファイルを `.env` という名前でコピーして、各値を埋めてください。
# `.env` は `.gitignore` で除外されているので、誤って公開される心配なし。
#
#    cp .env.example .env
#    chmod 600 .env  # 自分以外読めなくする
#
# 各値の取得手順は docs/ 配下を参照:
#   - Zoom API:        docs/03_ZOOM_API_SETUP.md
#   - OpenRouter:      docs/04_OPENROUTER_SETUP.md
#   - Discord Bot:     docs/05_DISCORD_BOT_SETUP.md
#   - Discord Webhook: docs/06_DISCORD_WEBHOOK_SETUP.md
#   - Google OAuth:    docs/07_GOOGLE_OAUTH_SETUP.md
#   - YouTube API:     docs/08_YOUTUBE_API_SETUP.md
#
# =====================================================


# -----------------------------------------------------
# 必須(全機能で必要)
# -----------------------------------------------------

# あなたのメインアカウントのメールアドレス(gog CLI 用)
GOG_ACCOUNT=your-email@gmail.com


# -----------------------------------------------------
# Zoom API (Server-to-Server OAuth)
# 取得方法: docs/03_ZOOM_API_SETUP.md
# -----------------------------------------------------

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=


# -----------------------------------------------------
# OpenRouter (要約生成用、Claude Haiku 4.5 経由)
# 取得方法: docs/04_OPENROUTER_SETUP.md
# 月数十円〜数百円程度の使用量
# -----------------------------------------------------

OPENROUTER_API_KEY=

# Anthropic 公式 API を直接使う場合(任意・OpenRouterの代替)
# ANTHROPIC_API_KEY=


# -----------------------------------------------------
# Discord Bot (Scheduled Events 作成用)
# 取得方法: docs/05_DISCORD_BOT_SETUP.md
# -----------------------------------------------------

DISCORD_BOT_TOKEN=


# -----------------------------------------------------
# Discord Webhook (告知・アーカイブ案内投稿用)
# 取得方法: docs/06_DISCORD_WEBHOOK_SETUP.md
#
# サーバーごと・用途ごとに別 Webhook を用意できる
# 名前は templates JSON の `discord_webhook_env` に書いたキー名と合わせる
# 下記は例。自分の運用に合わせて追加・削除・改名OK
# -----------------------------------------------------

# 講座サーバー1の「告知チャンネル」用
DISCORD_WEBHOOK_COURSE_NOTIFY=

# 講座サーバー1の「アーカイブ案内チャンネル」用
DISCORD_WEBHOOK_COURSE_ARCHIVE=

# コミュニティサーバーの「告知チャンネル」用
DISCORD_WEBHOOK_COMMUNITY_NOTIFY=

# コミュニティサーバーの「アーカイブ案内チャンネル」用
DISCORD_WEBHOOK_COMMUNITY_ARCHIVE=


# -----------------------------------------------------
# YouTube API (動画限定公開アップロード用)
# 取得方法: docs/08_YOUTUBE_API_SETUP.md
# 初回 youtube_oauth_setup.py 実行で REFRESH_TOKEN が自動セット
# -----------------------------------------------------

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=


# -----------------------------------------------------
# Google Calendar
# 「ゆえじSKD」のように予定を入れたいカレンダーIDを記入
# 取得方法: docs/07_GOOGLE_OAUTH_SETUP.md
# -----------------------------------------------------

GCAL_TARGET_CALENDAR=
